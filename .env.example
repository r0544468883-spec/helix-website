# Google Analytics 4 — Measurement ID from analytics.google.com
# (Admin → Data Streams → your web stream → "Measurement ID", format: G-XXXXXXXXXX)
# Leave unset locally so dev traffic is not tracked. Set it in Vercel for production.
NEXT_PUBLIC_GA_ID=G-NT22TNKPT4

# Meta (Facebook) Pixel — Pixel ID from Meta Events Manager
# (business.facebook.com/events_manager → Data Sources → your pixel → numeric ID)
# Set it in Vercel for production. Leave unset locally to avoid tracking dev traffic.
NEXT_PUBLIC_FB_PIXEL_ID=

# Resend — server-side API key for the /vibe-code workshop registration form
# Create one at resend.com → API Keys. Server-only — must NOT be prefixed NEXT_PUBLIC_.
# Real value goes in .env.local (gitignored), and in Vercel project settings.
RESEND_API_KEY=

# Inbox that receives workshop registration notifications.
# Default to Eran's working address until eran@helix.co.il is live via Google Workspace.
RESEND_NOTIFY_TO=eranlips@gmail.com
