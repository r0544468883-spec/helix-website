# Google Analytics 4 — Measurement ID from analytics.google.com
# (Admin → Data Streams → your web stream → "Measurement ID", format: G-XXXXXXXXXX)
# Leave unset locally so dev traffic is not tracked. Set it in Vercel for production.
NEXT_PUBLIC_GA_ID=G-NT22TNKPT4

# Meta (Facebook) Pixel — Pixel ID from Meta Events Manager
# (business.facebook.com/events_manager → Data Sources → your pixel → numeric ID)
# Set it in Vercel for production. Leave unset locally to avoid tracking dev traffic.
NEXT_PUBLIC_FB_PIXEL_ID=

# Resend — server-side API key for the /vibe-code workshop registration form
# Create one at resend.com → API Keys. Server-only — must NOT be prefixed NEXT_PUBLIC_.
# Real value goes in .env.local (gitignored), and in Vercel project settings.
RESEND_API_KEY=

# Inbox that receives workshop registration notifications.
# Default to Eran's working address until eran@helix.co.il is live via Google Workspace.
RESEND_NOTIFY_TO=eranlips@gmail.com

# ---------------------------------------------------------------------------
# /ai-checker — live AI-visibility layer (Layer A).
# ALL of these are OPTIONAL. With none set, the checker still runs the free
# Layer B checks (crawlability, structure, Common Crawl, Wikidata). Each key you
# add turns on that model's "does AI know/recommend you" probe. Connect these
# when the site moves to the main domain. Server-only — never NEXT_PUBLIC_.
#
# Perplexity Sonar (search-native, citations) — also powers the free teaser hook.
#   Get it at: perplexity.ai/settings/api
PERPLEXITY_API_KEY=
# Anthropic Claude (web_search tool). Get it at: console.anthropic.com
ANTHROPIC_API_KEY=
# OpenAI / ChatGPT (Responses API + web_search). Get it at: platform.openai.com/api-keys
OPENAI_API_KEY=
# Google Gemini (google_search grounding). Get it at: aistudio.google.com/apikey
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# /ai-checker — store every scanned site + lead in Supabase (optional).
# With these unset, scans still work; they just are not persisted.
# 1) Run docs/geo_scans.sql once in the Supabase SQL editor.
# 2) SUPABASE_URL — Project URL (Settings → API → Project URL).
# 3) SUPABASE_SERVICE_KEY — the service_role key (Settings → API). Server-only —
#    never expose it to the client / never prefix NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
