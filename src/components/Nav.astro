---
const links = [
  { href: '#capabilities', label: 'מה אנחנו עושים' },
  { href: '#paths', label: 'שירותים' },
  { href: '#faq', label: 'שו"ת' },
  { href: '#about', label: 'אודות' },
];
---

<nav class="nav" id="nav" aria-label="ראשי">
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="nav-logo">HELIX<span class="dot">.</span></a>
      <div class="nav-links">
        {links.map((link) => (
          <a href={link.href} class="nav-link">{link.label}</a>
        ))}
      </div>
      <a href="#cta" class="nav-cta">קבע שיחה</a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener(
    'scroll',
    () => {
      nav?.classList.toggle('scrolled', window.scrollY > 20);
    },
    { passive: true }
  );
</script>
