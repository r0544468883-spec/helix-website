---
interface Props {
  eyebrow?: string;
  title: string;
  titleHtml?: string;
  description?: string;
  as?: 'h1' | 'h2' | 'h3';
  class?: string;
}

const {
  eyebrow,
  title,
  titleHtml,
  description,
  as: Tag = 'h2',
  class: className = '',
} = Astro.props;
---

<div class={`section-header ${className}`}>
  {eyebrow && <span class="section-tag">{eyebrow}</span>}
  {titleHtml ? (
    <Tag class="section-title" set:html={titleHtml} />
  ) : (
    <Tag class="section-title">{title}</Tag>
  )}
  {description && <p class="section-desc">{description}</p>}
</div>
