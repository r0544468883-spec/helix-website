---
import SectionHeader from '../SectionHeader.astro';
import FAQItem from '../FAQItem.astro';

const faqs: { q: string; html: string }[] = [
  {
    q: 'כמה זה עולה?',
    html: `<p>אין מחיר אחיד באתר, ובכוונה. בפגישת האפיון אנחנו קובעים יחד את ה-scope ואת המחיר על בסיס מה שאתה באמת צריך. אם נפרסם מחיר באתר נהיה גרועים בשני הצדדים - או נציע זול מדי ונפסיד, או ננפח כדי "להיות בטוחים", וזה לא הוגן כלפיך.</p>
<p>מה שכן אפשר להגיד: <strong>Audit עולה בין 15-25K ש"ח. פרויקטי Launch בין 30-90K. רטיינר Grow בין 25-45K ש"ח לחודש.</strong> בשיחת ההיכרות נראה איפה אתה נופל ולמה.</p>`,
  },
  {
    q: 'כמה זמן זה לוקח?',
    html: `<p>תלוי בשירות:</p>
<p><strong>Audit:</strong> 2-3 שבועות מהפגישה הראשונה ועד מסמך מסכם.<br>
<strong>Launch:</strong> 4-8 שבועות, בהתאם לסקופ. פגישת אפיון בשבוע הראשון נותנת לוח זמנים מדויק.<br>
<strong>Grow:</strong> רטיינר חודשי. מינימום 3 חודשים כדי לראות תוצאות אמיתיות בקמפיינים.</p>`,
  },
  {
    q: 'אתם עובדים גם עם עסקים קטנים?',
    html: `<p>כן, וזה הקהל העיקרי שלי. עבדתי עם עמותות, רשתות בתי קפה, יזמים סולו, סטארטאפים בשלבי seed, וחברות B2B בינוניות. אם אתה צריך פיתוח + שיווק במעטפת אחת ולא רוצה לנהל 3 ספקים - אתה הקהל שלי.</p>
<p>החריג היחיד: אם התקציב שלך מתחת ל-10K ש"ח לפרויקט - כנראה שאני לא הספק הנכון, ובשיחה הראשונה אגיד לך את זה בכנות וימליץ על מישהו אחר.</p>`,
  },
  {
    q: 'מה ההבדל בינכם לסוכנות שיווק רגילה?',
    html: `<p>סוכנות שיווק רגילה עוסקת ב-channels (Google, Meta, SEO). היא לא נוגעת בקוד שלך, ולכן כשהקמפיין לא מומר - היא לא יודעת אם זה הקריאייטיב, ה-funnel, או באג בפיצ'ר. היא תשלח אותך לחברת פיתוח שלא תבין מה מבקש מהשיווק.</p>
<p>אצלנו זה אותו ראש. אם CPL גבוה, אני בודק את הקמפיין <strong>וגם</strong> את ה-conversion rate באתר. אם משהו תקוע, אני יכול לתקן את שני הצדדים. בלי handoffs בין ספקים שלא מדברים.</p>`,
  },
  {
    q: 'מי בעצם מבצע את העבודה - אתה לבד או צוות?',
    html: `<p>אני (ערן) מוביל אישית כל פרויקט. אני נמצא בכל פגישת סטטוס שבועית, אני אחראי על האסטרטגיה, ואני זה שכותב את הקוד הקריטי או בונה את הקמפיינים העיקריים.</p>
<p>לפרויקטים גדולים יותר יש לי רשת freelancers בכירים שאני סומך עליהם (מפתחי frontend, designers, קופירייטרים). אבל הם תמיד פועלים <strong>תחת Helix והאחריות שלי</strong>. הלקוח רואה רק אותי, ואני מנהל את מי שצריך.</p>`,
  },
  {
    q: 'אני לא יודע בדיוק מה אני צריך. אתם יכולים לעזור גם בזה?',
    html: `<p>זה בדיוק התפקיד של Helix Audit. הרבה פעמים בעלי עסקים יודעים ש"משהו לא עובד" אבל לא בטוחים אם זה בעיית מוצר, בעיית שיווק, או בעיית מסר.</p>
<p>ב-Audit אנחנו עוברים שיטתית על המוצר, הפאנל, הקמפיינים, וה-data, ויוצרים מסמך עם אבחנה ברורה ו-3 פעולות מתועדפות לפי ROI. אתה יכול לקחת את המסמך וללכת, או להמשיך איתנו ל-Launch או Grow.</p>`,
  },
  {
    q: 'מה קורה אם אתם מחליטים שהפרויקט לא מתאים לכם?',
    html: `<p>בשיחת ההיכרות הראשונה אני אגיד לך ישר. אם זה לא מתאים - כי אין לי את ההתמחות הנכונה, כי הזמן שלך לא תואם לזמן שלי, או כי אני חושב שמישהו אחר יעשה עבודה טובה יותר - אני אמליץ לך על מישהו אחר.</p>
<p>אני לא לוקח פרויקט שאני לא מאמין שאצליח בו. זה לא נחמדות - זו אסטרטגיה. פרויקט נכשל פוגע במוניטין יותר מפרויקט שלא לקחתי.</p>`,
  },
  {
    q: 'האם יש חוזים ארוכים?',
    html: `<p>לא. <strong>Audit</strong> הוא פרויקט נקודתי - שילמת, קיבלת, סיימת. <strong>Launch</strong> הוא פרויקט עם scope קבוע ומחיר קבוע - מסיימים את המשימה, נפרדים בידידות או ממשיכים.</p>
<p><strong>Grow</strong> הוא רטיינר חודשי שאפשר לסיים בכל חודש עם הודעה מראש של 30 יום. בלי חוזה לשנה, בלי קנסות יציאה. אם אנחנו לא מספקים ערך - אתה הולך.</p>`,
  },
];
---

<section class="faq" id="faq">
  <div class="container">
    <SectionHeader
      eyebrow="שאלות נפוצות"
      title="השאלות שכולם שואלים בשיחה הראשונה."
      titleHtml="השאלות שכולם<br>שואלים בשיחה הראשונה."
      description="אם יש לך שאלה שלא מופיעה כאן - פשוט תשאל בשיחת ההיכרות. אין שאלה טפשית, ואין שאלה שאני לא אענה ישר."
    />

    <div class="faq-list">
      {faqs.map((faq) => (
        <FAQItem question={faq.q}>
          <Fragment set:html={faq.html} />
        </FAQItem>
      ))}
    </div>
  </div>
</section>
