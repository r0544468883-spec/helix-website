---
interface Props {
  variant?: 'primary' | 'text';
  href?: string;
  type?: 'button' | 'submit';
  arrow?: 'left' | 'down' | null;
  class?: string;
}

const {
  variant = 'primary',
  href,
  type = 'button',
  arrow = null,
  class: className = '',
} = Astro.props;

const classes = ['btn', `btn-${variant}`, className].filter(Boolean).join(' ');
const arrowGlyph = arrow === 'down' ? '↓' : arrow === 'left' ? '←' : null;
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
      {arrowGlyph && <span class="btn-arrow">{arrowGlyph}</span>}
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
      {arrowGlyph && <span class="btn-arrow">{arrowGlyph}</span>}
    </button>
  )
}
